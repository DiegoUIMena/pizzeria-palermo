rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // FUNCIÓN AUXILIAR: Verificar si es Admin
    // ============================================
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isStaff() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ============================================
    // REGLAS PARA USUARIOS
    // ============================================
    match /users/{userId} {
      // Usuario puede leer su propia info, admin puede leer todo
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Usuario puede crear su propio perfil al registrarse
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Usuario puede actualizar su propia info, admin puede actualizar todo
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Solo admin puede eliminar usuarios
      allow delete: if isAdmin();
      
      // ============================================
      // SUBCOLLECTION: Historial de Puntos
      // ============================================
      match /points_history/{transactionId} {
        // Usuario puede leer su propio historial de puntos
        allow read: if isAuthenticated() && request.auth.uid == userId;
        
        // Las Cloud Functions escriben (no se permite desde cliente)
        allow write: if false;
      }
      
      // ============================================
      // SUBCOLLECTION: Vouchers Canjeados
      // ============================================
      match /vouchers/{voucherId} {
        // Usuario puede leer sus propios vouchers
        allow read: if isAuthenticated() && request.auth.uid == userId;
        
        // Las Cloud Functions escriben (no se permite desde cliente)
        allow write: if false;
      }
    }
    
    // ============================================
    // REGLAS PARA PEDIDOS (ORDERS)
    // ============================================
    match /orders/{orderId} {
      // Usuario ve sus propios pedidos, admin y staff ven todos
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        isStaff()
      );
      
      // Usuario autenticado puede crear pedidos
      // IMPORTANTE: En Fase 2 moveremos la creación a Cloud Functions
      allow create: if isAuthenticated() && 
                       request.auth.uid == request.resource.data.userId;
      
      // Solo admin y staff pueden actualizar pedidos (cambiar estados, etc)
      allow update: if isAdmin() || isStaff();
      
      // Solo admin puede eliminar pedidos
      allow delete: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA INVENTARIO
    // ============================================
    match /ingredientes/{ingredienteId} {
      // Todos pueden leer el inventario (necesario para mostrar disponibilidad)
      allow read: if true;
      
      // Solo admin puede modificar inventario
      allow write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA TRANSACCIONES DE INVENTARIO
    // ============================================
    match /inventory_transactions/{transactionId} {
      // Admin y staff pueden leer transacciones (para diagnósticos y auditoría)
      allow read: if isAdmin() || isStaff();
      
      // Las Cloud Functions escriben con privilegios admin
      // No se permite escritura directa desde el cliente
      allow write: if false;
    }
    
    // ============================================
    // REGLAS PARA CATÁLOGO DE MENÚ
    // ============================================
    match /items_menu/{itemId} {
      // Todos pueden leer el menú
      allow read: if true;
      
      // Solo admin puede modificar el menú
      allow write: if isAdmin();
    }
    
    match /categorias_menu/{categoriaId} {
      // Todos pueden leer las categorías
      allow read: if true;
      
      // Solo admin puede modificar categorías
      allow write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA ZONAS DE DELIVERY
    // ============================================
    match /delivery-zones/{zoneId} {
      // Todos pueden leer zonas (necesario para validar direcciones)
      allow read: if true;
      
      // Solo admin puede crear/modificar/eliminar zonas
      allow write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA CONFIGURACIÓN DE PIZZAS
    // ============================================
    match /pizza_config/{configId} {
      // Todos pueden leer la configuración de pizzas
      allow read: if true;
      
      // Solo admin puede modificar configuración
      allow write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA CONFIGURACIÓN DE HORARIOS
    // ============================================
    match /settings/{settingId} {
      // Todos pueden leer la configuración (para mostrar horarios y banner cuando está cerrado)
      allow read: if true;
      
      // Solo admin puede modificar configuración
      allow write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA CÓDIGOS PROMOCIONALES
    // ============================================
    match /promociones/{promoId} {
      // Solo los administradores pueden leer, crear y editar los códigos
      allow read, write: if isAdmin();
    }
    
    // ============================================
    // REGLAS PARA CHATBOT (Multi-tenant)
    // ============================================
    
    // Configuración general del tenant
    match /tenants/{tenantId} {
      // Todos pueden leer la configuración del chatbot (para saber si está habilitado)
      allow read: if true;
      
      // Solo admin puede modificar la configuración del tenant
      allow write: if isAdmin();
      
      // Intents del chatbot
      match /chatbot_intents/{intentId} {
        // Todos pueden leer los intents si el chatbot está habilitado
        allow read: if true;
        
        // Solo admin puede crear/modificar/eliminar intents
        allow write: if isAdmin();
      }
      
      // Sesiones de chat (cada usuario tiene su propia sesión)
      match /chat_sessions/{sessionId} {
        // Usuarios autenticados pueden leer/escribir sus propias sesiones
        // Las Cloud Functions usan privilegios admin para crear/actualizar
        allow read: if true; // Necesario para que el widget funcione sin login
        allow create: if true; // Las Cloud Functions crean las sesiones
        allow update: if true; // Las Cloud Functions actualizan las sesiones
        allow delete: if isAdmin(); // Solo admin puede eliminar sesiones
      }
      
      // Logs de conversaciones
      match /chat_logs/{logId} {
        // Solo admin puede leer los logs
        allow read: if isAdmin();
        
        // Las Cloud Functions escriben con privilegios admin
        // No se permite escritura directa desde el cliente
        allow write: if false;
      }
      
      // Métricas del chatbot
      match /chatbot_metrics/{metricId} {
        // Admin puede leer las métricas
        allow read: if isAdmin();
        
        // Las Cloud Functions escriben con privilegios admin
        // No se permite escritura directa desde el cliente
        allow write: if false;
      }
      
      // Preguntas sin respuesta
      match /unanswered_questions/{questionId} {
        // Solo admin puede leer las preguntas sin respuesta
        allow read: if isAdmin();
        
        // Solo admin puede actualizar el estado
        allow update: if isAdmin();
        
        // Las Cloud Functions crean con privilegios admin
        allow create: if false;
        allow delete: if isAdmin();
      }
    }
    
    // ============================================
    // BLOQUEAR TODO LO DEMÁS POR DEFECTO
    // ============================================
    // Esta regla bloquea cualquier colección no especificada arriba
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
